rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /posts/{postId} {
      allow read: if true;

      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.autor == request.auth.token.email
        && request.resource.data.titulo is string
        && request.resource.data.titulo.size() > 0
        && request.resource.data.titulo.size() <= 30
        && request.resource.data.descripcion is string
        && request.resource.data.descripcion.size() > 0
        && request.resource.data.descripcion.size() <= 200
        && request.resource.data.videoLink is string
        && request.resource.data.videoLink.size() > 0;

      allow update, delete: if request.auth != null
        && resource.data.uid == request.auth.uid;
    }

    match /tokens/{tokenId} {
      allow create, update: if request.auth != null;
      allow read, delete: if false;
    }
  }
}
