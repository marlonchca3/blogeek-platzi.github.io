.btnPpal
	
	background colorAccent !important 
	font-family 'Montserrat', sans-serif
	font-weight bold		
	transition .5s
			
	&:hover
		background colorAccent
		color white
		font-size 17px

body
	font-family: 'Allerta', sans-serif;
	
.headerppal
	background colorPrimario
	overflow hidden
	box-shadow 0 8px 10px rgba(0,0,0,0.5)
	padding-bottom 30px
	text-align center
	
	.titulo
		color colorBlanco
		font-size 40px
		font-family 'Montserrat', sans-serif
		margin-top 30px
		margin-bottom 0
		
	.titulo-a		
		color colorBlanco
		font-size 20px
		padding-top 5px		
		padding-bottom 15px
	
	.header-logotipo
		margin-right 5em
		margin-left 50px
		margin-top 20px		
		
		img	
			border-right-style solid
			border-width 2px
			border-color white
			border-radius 60%
			height 140px
			padding 20px
			width 140px
			transition .6s
			
			&:hover
				transform scale(1.2)
		
	.header-avatar
		display none
		float right
		margin-top -200px
		margin-right 50px
		
		img
			border-radius 60%
			height 80px
			width 80px
			transition .6s
			transform translateY(100px)
										
.menu
	background colorAzulAguaMarina
	border-left 10px solid white
	box-shadow 0 8px 10px rgba(0,0,0,0.5)
	
	ul
		margin 0px
		
		li 
			display block
			line-height 40px
			transition .6s
			
			&:hover
				background colorPrimario	
			
			a 
				color colorBlanco
				text-decoration none
				padding 0 1em
				transition .6s
				
				&:hover
					font-size 17px	

.footer
	
